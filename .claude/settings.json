{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(terraform import*)",
      "Bash(terraform state rm*)",
      "Bash(terraform state push*)",
      "Bash(aws *)",
      "Bash(aws*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)",
      "Read(**/*.tfstate*)"
    ],
    "allow": [
      "Bash(terraform fmt*)",
      "Bash(terraform validate*)",
      "Bash(terraform init -backend=false*)",
      "Bash(terraform plan*)",
      "Bash(terraform test*)",
      "Bash(terraform providers*)",
      "Bash(terraform-docs*)",
      "Bash(tflint*)",
      "Bash(checkov*)"
    ]
  }
}
